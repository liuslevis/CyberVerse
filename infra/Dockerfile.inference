FROM pytorch/pytorch:2.7.1-cuda12.8-cudnn9-runtime

# Runtime dependencies (ffmpeg for audio IO; keep it minimal).
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install only runtime Python deps we need in the container.
# Note: torch is provided by the base image to avoid slow downloads of NVIDIA
# split-wheel dependencies during image build in some regions.
COPY pyproject.toml .
RUN python -m pip install --no-cache-dir --upgrade pip setuptools wheel && \
    python -m pip install --no-cache-dir \
    "numpy>=1.24" \
    "pyyaml>=6.0" \
    "grpcio>=1.60" \
    "grpcio-health-checking>=1.60" \
    "websockets>=12.0" \
    "openai>=1.0" \
    "openai-whisper>=20231117" \
    pillow \
    scipy \
    "diffusers>=0.34.0" \
    transformers==4.57.3 \
    "tokenizers>=0.20.3" \
    "accelerate>=1.8.1" \
    safetensors \
    einops \
    loguru \
    pyloudnorm \
    tqdm

COPY inference/ ./inference/
COPY models/flash_head/ ./models/flash_head/
COPY models/SoulX-LiveAct/ ./models/SoulX-LiveAct/
COPY cyberverse_config.yaml .

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import grpc; ch = grpc.insecure_channel('localhost:50051'); grpc.channel_ready_future(ch).result(timeout=3)" || exit 1

EXPOSE 50051
CMD ["python", "-m", "inference.server", "--config", "cyberverse_config.yaml"]
